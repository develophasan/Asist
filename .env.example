# Copy to apps/api/.env for local API development

NODE_ENV=development
PORT=3000

# PostgreSQL (matches docker-compose defaults)
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USER=asist
DATABASE_PASSWORD=asist
DATABASE_NAME=asist

# TypeORM — never enable in production without migrations
TYPEORM_SYNC=true

# Redis / BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT (generate strong secrets for production)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
